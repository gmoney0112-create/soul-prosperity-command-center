# Soul Prosperity Command Center — server-side env vars
#
# These are read by the serverless functions under /api/ghl/*. None of
# them are read by the static dashboard. Configure them in your Vercel
# project (Settings → Environment Variables) for Production, Preview,
# and Development as appropriate. For local serverless testing with
# `vercel dev`, copy this file to `.env.local` and fill in real values.
#
# Public, browser-safe identifiers (location id, public client id,
# install URL, redirect URI as a URL, scopes, webhook target URL,
# operator entry URLs) live in the static `config.js` under
# window.SP_CONFIG.ghl — NOT here.

# ── OAuth (token exchange) ─────────────────────────────────────────
# Public Marketplace client_id. Same value as SP_CONFIG.ghl.oauth.clientId.
GHL_CLIENT_ID=
# Marketplace client_secret. NEVER expose to the browser; keep in
# Vercel encrypted env vars only. Rotate immediately if leaked.
GHL_CLIENT_SECRET=
# Where HighLevel redirects after install. Must be HTTPS and exactly
# match the value registered in the Marketplace app. Mirrors
# SP_CONFIG.ghl.oauth.redirectUri. For this repo's serverless layer,
# the canonical value is:
#   https://<your-domain>/api/ghl/oauth/callback
GHL_OAUTH_REDIRECT_URI=
# Token type — almost always "Location" for sub-account installs.
# Use "Company" only if the Marketplace app is agency-scoped.
GHL_USER_TYPE=Location

# ── Token persistence — Vercel KV (preferred) ──────────────────────
# Vercel injects these automatically when you connect a KV store to
# the project. Dashboard: Project → Storage → Connect KV Store →
# select an existing store or create one (free tier available).
# When both vars are present the OAuth callback stores tokens under
# ghl:oauth:<locationId> with a 30-day TTL via the Upstash REST API.
# No code changes or extra packages are required.
#
# If KV is configured, GHL_TOKEN_STORAGE_URL below is optional.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Token persistence — HTTP sink (fallback) ────────────────────────
# Used only when KV vars above are absent. After token exchange, the
# OAuth callback POSTs the token bundle as JSON to this URL. This is
# the production storage boundary — a server-to-server endpoint YOU
# own (your own API route writing to a DB, Make/Zapier webhook, etc.).
# If unset AND KV is not configured, /api/ghl/oauth/callback will
# return `persisted: false` with an explicit operator warning. Tokens
# are NOT silently dropped, but they ARE NOT stored either. Configure
# at least one storage option before pointing real installs at the
# redirect URI.
GHL_TOKEN_STORAGE_URL=

# ── Webhooks ───────────────────────────────────────────────────────
#
# NOTE: There is intentionally no GHL_WEBHOOK_SIGNING_SECRET. HighLevel
# signs webhook deliveries with PUBLIC-KEY cryptography:
#   - Current scheme: Ed25519, header `X-GHL-Signature` (base64).
#   - Legacy scheme:  RSA-SHA256, header `X-WH-Signature` (base64).
# The matching public keys are published by HighLevel and embedded in
# api/_lib/ghl.js. Verification is built-in and requires no env secret.
# Do not add a shared-secret HMAC step — that is not the official
# HighLevel scheme and would reject real deliveries.
#
# Optional. If set, /api/ghl/webhook forwards each accepted delivery
# (verified, de-duped, allowlisted) to this URL as JSON. If unset, the
# handler logs sanitized metadata and ack's HighLevel anyway. Use this
# to fan out into a queue, KV, or your own pipeline.
GHL_WEBHOOK_FORWARD_URL=
# Optional. Comma-separated allowlist of event types. Defaults to:
#   ContactCreate,ContactUpdate,ContactTagUpdate,OpportunityCreate,
#   OpportunityStatusUpdate,InboundMessage,OutboundMessage,
#   OrderCreate,AppInstall,AppUninstall
# Anything outside the list is acked 200 (no retry) but ignored.
GHL_ALLOWED_WEBHOOK_EVENTS=
